# 0G Compute Router API key
OG_ROUTER_API_KEY=sk-your-key-here

# 0G Router endpoint
OG_ROUTER_BASE_URL=https://router-api.0g.ai/v1

# AI model to use for predictions
OG_MODEL=zai-org/GLM-5-FP8

# 0G Chain RPC
OG_CHAIN_RPC=https://evmrpc.0g.ai

# OracleRegistry contract address (deployed on 0G Chain)
REGISTRY_CONTRACT=0x...

# Agent private key (for signing transactions on 0G Chain)
AGENT_PRIVATE_KEY=0x...

# Storage configuration
OG_STORAGE_RPC=https://evmrpc.0g.ai
OG_STORAGE_INDEXER=https://indexer-storage-turbo.0g.ai

# Server port
PORT=3000
